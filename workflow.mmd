flowchart TD

%% =========================
%% USERS & FRONTEND
%% =========================
U[HR Manager / User] --> FE[Next.js Frontend]
FE --> BE[Next.js Backend API Layer]
BE --> API[FastAPI Backend]

%% =========================
%% AGENTIC AI PLATFORM CORE
%% =========================
API --> PLATFORM[LangGraph Orchestration Engine]
PLATFORM --> HR["HR Agent (Domain-Specific)"]

%% =========================
%% LLM LAYER
%% =========================
HR --> LLM["Groq LLM (Llama 3.1 / 70B)"]

%% =========================
%% INTERACTIVE CHAT MODULE
%% =========================
FE --> CHAT[HR Chat Interface]
CHAT <--> HR
CHAT --> DB[(MongoDB)]

%% =========================
%% SEQUENTIAL WORKFLOW PIPELINE
%% =========================
HR --> W1[Candidate Screening & Ranking]
W1 --> W2[Interview Scheduling]
W2 --> W3[Onboarding]

W1 --> W2 --> W3

%% =========================
%% WORKFLOW 1 - SCREENING
%% =========================
W1 --> GMAIL1[Gmail API - Fetch Resumes]
LLM --> W1

%% =========================
%% WORKFLOW 2 - INTERVIEW SCHEDULING
%% =========================
W2 --> GMAIL2[Gmail API - Send Emails]
W3 --> GMAIL3[Gmail API - Acceptance/Rejection Emails]
W2 --> MEET[Google Meet - Generate Links]
W2 --> CAL[Google Calendar - Events]


MEET --> CAL --> GMAIL2

%% =========================
%% WORKFLOW 3 - ONBOARDING
%% =========================
W3 --> DB

%% =========================
%% DATA ACCESS (CENTRALIZED)
%% =========================
W1 --> DB
W2 --> DB

LLM --> W2
LLM --> W3

